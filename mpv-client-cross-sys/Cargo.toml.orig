[package]
name = "mpv-client-cross-sys"
description = "Raw bindings for libmpv client API"
keywords = ["mpv", "libmpv", "ffi"]
categories = ["external-ffi-bindings"]
version.workspace = true
edition.workspace = true
authors.workspace = true
license.workspace = true
repository.workspace = true
readme.workspace = true
build = "build.rs"

[features]
default = []
bindgen = [
    "dep:bindgen",
    "dep:syn",
    "dep:quote",
    "dep:proc-macro2",
    "dep:prettyplease",
]

[build-dependencies]
bindgen = { workspace = true, optional = true }

[target.'cfg(any(target_os = "windows", target_os = "android"))'.build-dependencies]
syn = { workspace = true, optional = true }
quote = { workspace = true, optional = true }
proc-macro2 = { workspace = true, optional = true }
prettyplease = { workspace = true, optional = true }

[lints]
workspace = true
